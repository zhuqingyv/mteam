{
  "name": "@mcp-team-hub/backend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "mcp": "bun run src/mcp/index.ts",
    "build": "bun build src/server.ts --outdir dist --target node",
    "build:mcp": "bun build src/mcp/index.ts --outdir dist/mcp --target node",
    "typecheck": "bunx tsc --noEmit",
    "test": "npx vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "better-sqlite3": "^12.9.0",
    "node-pty": "^1.1.0",
    "uuid": "^11.1.0"
  },
  "bin": {
    "team-hub": "./src/server.ts",
    "mcp-team-hub-mteam": "./src/mcp/index.ts"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
